#!/usr/bin/env bb
;; Blast Radius launcher. ZERO setup: `bbin install` this script, then run it.
;;
;; On first run it fetches the engine — a self-contained JVM uberjar — and caches it under
;; ~/.cache/blast-radius/<version>/; every run after is plain `java`. No env vars, no clone, no
;; config required. The engine is resolved by the first of these that succeeds:
;;   1. download the published GitHub Release jar   (default — needs only curl + java)
;;   2. build from source: clone the repo at the release tag and `clojure -T:build uber`
;;      (automatic fallback when the release asset is unavailable; needs the clojure CLI once)
;; Optional overrides (none required): $BLAST_RADIUS_JAR (use this jar as-is),
;; $BLAST_RADIUS_HOME (build from this local checkout), $BLAST_RADIUS_JAR_URL /
;; $BLAST_RADIUS_JAR_HEADER (custom/private asset URL + auth header).
;;
;; Usage (run from the repo to analyze; optional .blast-radius.edn for project config):
;;   blast-radius "$(git merge-base origin/main HEAD)..HEAD"
;;   blast-radius <commit> [--out-file … --trust-keywords :db/id,:company/id …]

(require '[babashka.fs :as fs]
         '[babashka.process :as process])

(def ^:private version "v0.1.0")
(def ^:private repo-url "https://github.com/fulcrologic/blast-radius.git")
(def ^:private release-jar-url
  (str "https://github.com/fulcrologic/blast-radius/releases/download/" version "/blast-radius.jar"))
(def ^:private cache-dir (fs/file (fs/xdg-cache-home) "blast-radius" version))
(def ^:private jar (fs/file cache-dir "blast-radius.jar"))

(defn- log [& xs] (binding [*out* *err*] (apply println "blast-radius:" xs)))

(defn- download!
  "Downloads the engine jar from `url` into the cache. Honors $BLAST_RADIUS_JAR_HEADER (e.g.
   \"PRIVATE-TOKEN: …\") for authenticated/private assets. True on success."
  [url]
  (log "fetching engine" version "…")
  (let [hdr  (System/getenv "BLAST_RADIUS_JAR_HEADER")
        argv (cond-> ["curl" "-fsSL" "-o" (str jar)] hdr (conj "-H" hdr) :always (conj url))]
    (and (zero? (:exit (apply process/shell {:continue true} argv))) (fs/exists? jar))))

(defn- build-from!
  "Builds the uberjar from checkout `src` (`clojure -T:build uber`) and caches it. True on success."
  [src]
  (log "building engine from" (str src) "…")
  (process/shell {:dir (str src) :continue true :out :inherit :err :inherit} "clojure" "-T:build" "uber")
  (let [built (fs/file src "target" "blast-radius.jar")]
    (when (fs/exists? built) (fs/copy built jar {:replace-existing true}) (fs/exists? jar))))

(defn- clone-and-build!
  "Clones the repo at the release tag into the cache and builds the engine. True on success."
  []
  (let [src (fs/file cache-dir "repo")]
    (when-not (fs/exists? src)
      (log "cloning" repo-url "at" version "…")
      (process/shell {:continue true} "git" "clone" "--quiet" "--branch" version "--depth" "1"
                     repo-url (str src)))
    (and (fs/exists? src) (build-from! src))))

(defn- ensure-jar! []
  (fs/create-dirs cache-dir)
  (when-not (fs/exists? jar)
    (or (when-let [j (System/getenv "BLAST_RADIUS_JAR")] (when (fs/exists? j) (fs/copy j jar) true))
        (when-let [h (System/getenv "BLAST_RADIUS_HOME")] (build-from! h))
        (download! (or (System/getenv "BLAST_RADIUS_JAR_URL") release-jar-url))
        (clone-and-build!)))
  (when-not (fs/exists? jar)
    (log "could not obtain the engine (need curl+java to download, or git+clojure to build).")
    (System/exit 1)))

(ensure-jar!)
;; exec replaces this bb process with the JVM, forwarding stdout/stderr and the exit code.
(process/exec (into ["java" "-cp" (str jar) "clojure.main" "-m" "blast-radius.cli"]
                    (vec *command-line-args*)))
