#!/usr/bin/env bb
;; Blast Radius launcher — a tiny Babashka wrapper that execs a JVM with the right classpath.
;; bb gives the easy bbin install + fast CLI startup; the JVM does the heavy build (native
;; clj-kondo analysis + graph transforms), which is several-fold faster than sci.
;;
;; ENGINE RESOLUTION (first match wins) — the goal is a JAVA-ONLY runtime (no clojure CLI),
;; with the uberjar built/cached on demand so nothing has to be published:
;;   1. $BLAST_RADIUS_JAR                         -> use that jar.
;;   2. $BLAST_RADIUS_HOME (a local checkout)     -> BUILD-IF-STALE into the cache, then use it
;;                                                   (`clojure -T:build uber`; one-time / on change).
;;   3. ~/.cache/blast-radius/blast-radius.jar    -> a previously built/downloaded jar.
;;   4. $BLAST_RADIUS_JAR_URL                      -> download to the cache (published release).
;;   5. pinned git coordinate via the clojure CLI -> last-resort, no jar.
;; Paths 1–4 run `java -cp <jar> clojure.main -m blast-radius.cli …` (no clojure CLI at runtime;
;; building in path 2 needs the clojure CLI once). Path 5 needs the clojure CLI per run.
;;
;; Usage (run from the repo to analyze; config in its .blast-radius.edn):
;;   blast-radius "$(git merge-base origin/main HEAD)..HEAD"
;;   blast-radius <commit> [--out-file … --trust-keywords :db/id,:company/id …]

(require '[babashka.fs :as fs]
         '[babashka.process :as process])

(def ^:private cached-jar (fs/file (fs/xdg-cache-home) "blast-radius" "blast-radius.jar"))

(defn- newer-than? [path t]
  (and (fs/exists? path) (pos? (compare (fs/last-modified-time path) t))))

(defn- stale?
  "True when `jar` is missing or older than any source/deps/build file under checkout `home`."
  [jar home]
  (or (not (fs/exists? jar))
      (let [t (fs/last-modified-time jar)]
        (boolean
         (or (some #(newer-than? (fs/file home %) t) ["deps.edn" "build.clj"])
             (seq (filter #(pos? (compare (fs/last-modified-time %) t))
                          (fs/glob home "{src,resources}/**"))))))))

(defn- build-and-cache!
  "Builds the uberjar from checkout `home` (`clojure -T:build uber`) and copies it into the
   cache. Returns the cached jar path, or nil on failure (caller falls through)."
  [home]
  (binding [*out* *err*] (println "blast-radius: building engine jar (one-time / on change) …"))
  (let [{:keys [exit]} (process/shell {:dir home :continue true :out :inherit :err :inherit}
                                      "clojure" "-T:build" "uber")
        built (fs/file home "target" "blast-radius.jar")]
    (when (and (zero? exit) (fs/exists? built))
      (fs/create-dirs (fs/parent cached-jar))
      (fs/copy built cached-jar {:replace-existing true})
      (str cached-jar))))

(defn- download!
  "Downloads the engine jar from `url` to the cache. For a PRIVATE GitLab package registry, set
   $BLAST_RADIUS_JAR_HEADER (e.g. \"PRIVATE-TOKEN: glpat-…\" or \"JOB-TOKEN: …\") — it is passed
   as a curl header so the token is not baked into the URL."
  [url]
  (fs/create-dirs (fs/parent cached-jar))
  (binding [*out* *err*] (println "blast-radius: downloading engine jar …"))
  (let [header (System/getenv "BLAST_RADIUS_JAR_HEADER")
        argv   (cond-> ["curl" "-fsSL" "-o" (str cached-jar)]
                 header (conj "-H" header)
                 true   (conj url))
        {:keys [exit]} (apply process/shell {:continue true} argv)]
    (when (zero? exit) (str cached-jar))))

(defn- resolve-jar []
  (let [explicit (System/getenv "BLAST_RADIUS_JAR")
        home     (System/getenv "BLAST_RADIUS_HOME")
        url      (System/getenv "BLAST_RADIUS_JAR_URL")]
    (cond
      (and explicit (fs/exists? explicit)) explicit
      (and home (fs/exists? (fs/file home "build.clj")))
      (if (stale? cached-jar home) (build-and-cache! home) (str cached-jar))
      (fs/exists? cached-jar) (str cached-jar)
      url                     (download! url)
      :else                   nil)))

(defn- command []
  (let [args (vec *command-line-args*)]
    (if-let [jar (resolve-jar)]
      (into ["java" "-cp" jar "clojure.main" "-m" "blast-radius.cli"] args)
      (let [home  (System/getenv "BLAST_RADIUS_HOME")
            sdeps (if home
                    (format "{:deps {io.github.fulcrologic/blast-radius {:local/root \"%s\"}}}" home)
                    ;; Public GitHub repo — resolved over HTTPS, no creds needed.
                    "{:deps {io.github.fulcrologic/blast-radius {:git/sha \"REPLACE_WITH_PINNED_SHA\"}}}")]
        (into ["clojure" "-Sdeps" sdeps "-M" "-m" "blast-radius.cli"] args)))))

;; exec replaces this bb process with the JVM, forwarding stdout/stderr and the exit code.
(process/exec (command))
